generator client {
  provider = "prisma-client-js"
  output   = "./generated/client_next"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum PeranAdmin {
  superadmin
  admin
}

enum StatusPublikasi {
  draft
  terbit
}

model AkunAdmin {
  idAdmin       Int            @id @default(autoincrement()) @map("id_admin") @db.UnsignedInt
  namaPengguna  String         @unique @map("nama_pengguna") @db.VarChar(80)
  namaLengkap   String         @map("nama_lengkap") @db.VarChar(140)
  kataSandiHash String         @map("kata_sandi_hash") @db.Char(64)
  peran         PeranAdmin     @default(superadmin)
  idRole        Int?           @map("id_role") @db.UnsignedInt
  aktif         Boolean        @default(true)
  dibuatPada    DateTime       @default(now()) @map("dibuat_pada") @db.Timestamp(0)
  sesiAdmin     SesiAdmin[]
  role          RolePengguna?  @relation("RoleAkunAdmin", fields: [idRole], references: [idRole], onDelete: SetNull)

  @@index([idRole], map: "idx_akun_admin_role")
  @@map("akun_admin")
}

model SesiAdmin {
  idSesi         String    @id @map("id_sesi") @db.Char(64)
  idAdmin        Int       @map("id_admin") @db.UnsignedInt
  ipPengguna     String?   @map("ip_pengguna") @db.VarChar(60)
  agenPengguna   String?   @map("agen_pengguna") @db.VarChar(255)
  dibuatPada     DateTime  @default(now()) @map("dibuat_pada") @db.DateTime(0)
  kedaluwarsaPada DateTime @map("kedaluwarsa_pada") @db.DateTime(0)
  admin          AkunAdmin @relation(fields: [idAdmin], references: [idAdmin], onDelete: Cascade)

  @@index([idAdmin], map: "idx_sesi_admin_id_admin")
  @@index([kedaluwarsaPada], map: "idx_sesi_admin_kedaluwarsa")
  @@map("sesi_admin")
}

model RolePengguna {
  idRole     Int            @id @default(autoincrement()) @map("id_role") @db.UnsignedInt
  namaRole   String         @unique @map("nama_role") @db.VarChar(80)
  deskripsi  String?        @db.VarChar(255)
  dibuatPada DateTime       @default(now()) @map("dibuat_pada") @db.Timestamp(0)
  izinMenu   IzinRoleMenu[]
  akunAdmin  AkunAdmin[]    @relation("RoleAkunAdmin")

  @@map("role_pengguna")
}

model MenuAdmin {
  idMenu   Int            @id @default(autoincrement()) @map("id_menu") @db.UnsignedInt
  kunci    String         @unique @db.VarChar(60)
  label    String         @db.VarChar(100)
  href     String         @db.VarChar(200)
  ikon     String         @db.VarChar(60)
  grup     String         @db.VarChar(60)
  urutan   Int            @default(0) @db.UnsignedInt
  aktif    Boolean        @default(true)
  izinRole IzinRoleMenu[]

  @@index([urutan], map: "idx_menu_admin_urutan")
  @@map("menu_admin")
}

model IzinRoleMenu {
  idIzin Int          @id @default(autoincrement()) @map("id_izin") @db.UnsignedInt
  idRole Int          @map("id_role") @db.UnsignedInt
  idMenu Int          @map("id_menu") @db.UnsignedInt
  role   RolePengguna @relation(fields: [idRole], references: [idRole], onDelete: Cascade)
  menu   MenuAdmin    @relation(fields: [idMenu], references: [idMenu], onDelete: Cascade)

  @@unique([idRole, idMenu])
  @@index([idRole], map: "idx_izin_role")
  @@index([idMenu], map: "idx_izin_menu")
  @@map("izin_role_menu")
}

model KategoriBerita {
  idKategori   Int      @id @default(autoincrement()) @map("id_kategori") @db.UnsignedInt
  namaKategori String   @unique @map("nama_kategori") @db.VarChar(100)
  slug         String   @unique @db.VarChar(130)
  aktif        Boolean  @default(true)
  dibuatPada   DateTime @default(now()) @map("dibuat_pada") @db.Timestamp(0)

  @@map("kategori_berita")
}

model Berita {
  idBerita         Int             @id @default(autoincrement()) @map("id_berita") @db.UnsignedInt
  judul            String          @db.VarChar(220)
  slug             String          @unique @db.VarChar(260)
  ringkasan        String          @db.Text
  isiPenuh         String          @map("isi_penuh") @db.LongText
  kategori         String          @db.VarChar(100)
  penulis          String          @db.VarChar(120)
  gambarUrl        String?         @map("gambar_url") @db.VarChar(255)
  tagJson          String?         @map("tag_json") @db.LongText
  estimasiBacaMenit Int            @default(4) @map("estimasi_baca_menit") @db.UnsignedInt
  jumlahDilihat    Int             @default(0) @map("jumlah_dilihat") @db.UnsignedInt
  adalahPenting    Boolean         @default(false) @map("adalah_penting")
  prioritasPenting Int             @default(0) @map("prioritas_penting")
  statusPublikasi  StatusPublikasi @default(terbit) @map("status_publikasi")
  tanggalTerbit    DateTime        @default(now()) @map("tanggal_terbit") @db.DateTime(0)
  dibuatPada       DateTime        @default(now()) @map("dibuat_pada") @db.Timestamp(0)
  diubahPada       DateTime        @updatedAt @map("diubah_pada") @db.Timestamp(0)

  @@index([tanggalTerbit], map: "idx_berita_terbit")
  @@index([adalahPenting, prioritasPenting], map: "idx_berita_penting")
  @@index([statusPublikasi], map: "idx_berita_status")
  @@map("berita")
}

model Pejabat {
  idPejabat  Int      @id @default(autoincrement()) @map("id_pejabat") @db.UnsignedInt
  nama       String   @db.VarChar(160)
  jabatan    String   @db.VarChar(200)
  singkatan  String   @default("") @db.VarChar(10)
  email      String   @default("") @db.VarChar(160)
  telepon    String   @default("") @db.VarChar(30)
  bidangJson String?  @map("bidang_json") @db.Text
  fotoUrl    String?  @map("foto_url") @db.VarChar(255)
  urutan     Int      @default(99) @db.UnsignedInt
  aktif      Boolean  @default(true)
  dibuatPada DateTime @default(now()) @map("dibuat_pada") @db.Timestamp(0)
  diubahPada DateTime @updatedAt @map("diubah_pada") @db.Timestamp(0)

  @@index([urutan], map: "idx_pejabat_urutan")
  @@map("pejabat")
}

model Dosen {
  idDosen          Int      @id @default(autoincrement()) @map("id_dosen") @db.UnsignedInt
  slug             String   @unique @db.VarChar(200)
  nama             String   @db.VarChar(160)
  gelar            String   @default("") @db.VarChar(80)
  jabatan          String   @db.VarChar(200)
  bidangKeahlianJson String? @map("bidang_keahlian_json") @db.Text
  deskripsi        String   @db.Text
  email            String   @default("") @db.VarChar(160)
  ruang            String   @default("") @db.VarChar(100)
  fotoUrl          String?  @map("foto_url") @db.VarChar(255)
  jurnalJson       String?  @map("jurnal_json") @db.LongText
  aktif            Boolean  @default(true)
  urutan           Int      @default(99) @db.UnsignedInt
  dibuatPada       DateTime @default(now()) @map("dibuat_pada") @db.Timestamp(0)
  diubahPada       DateTime @updatedAt @map("diubah_pada") @db.Timestamp(0)

  @@index([slug], map: "idx_dosen_slug")
  @@index([urutan], map: "idx_dosen_urutan")
  @@map("dosen")
}

model StatistikBeranda {
  idStatistik     Int      @id @default(1) @map("id_statistik") @db.UnsignedInt
  totalTaruna     Int      @default(1735) @map("total_taruna") @db.UnsignedInt
  totalAlumni     Int      @default(15000) @map("total_alumni") @db.UnsignedInt
  tahunPengabdian Int      @default(64) @map("tahun_pengabdian") @db.UnsignedInt
  totalPengunjung Int      @default(0) @map("total_pengunjung") @db.UnsignedInt
  dibuatPada      DateTime @default(now()) @map("dibuat_pada") @db.Timestamp(0)
  diubahPada      DateTime @updatedAt @map("diubah_pada") @db.Timestamp(0)

  @@map("statistik_beranda")
}
